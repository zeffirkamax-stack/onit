@model Laba3.Models.PhoneNumber

@{
    ViewData["Title"] = "Edit Contact";
}

<h1>Edit Contact</h1>

<div class="page-card" style="max-width: 480px;">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        <div class="form-group">
            <label class="control-label">Phone Number</label>
            <input asp-for="Number" class="form-control" />
            <span asp-validation-for="Number" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="EmployeeID" class="control-label"></label>
            <select asp-for="EmployeeID" class="form-control" asp-items="ViewBag.EmployeeID"></select>
            <span asp-validation-for="EmployeeID" class="text-danger"></span>
        </div>
        <input type="submit" value="Save" />
    </form>
</div>

<a class="back-link" asp-action="Index">&#8592; Back to list</a>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
