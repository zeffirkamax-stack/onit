@model Laba3.Models.PhoneNumber

@{
    ViewData["Title"] = "Contact Details";
}

<h1>Contact Details</h1>

<div class="info-block">
    <div class="info-row">
        <span class="info-label">Phone Number</span>
        <span class="info-value">@Html.DisplayFor(model => model.Number)</span>
    </div>
    <div class="info-row">
        <span class="info-label">Employee ID</span>
        <span class="info-value">@Html.DisplayFor(model => model.Employee.Id)</span>
    </div>
    <div class="info-row">
        <span class="info-label">Employee</span>
        <span class="info-value">@Html.DisplayFor(model => model.Employee.Name)</span>
    </div>
</div>

<div class="action-links">
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a>
    <a asp-action="Index">Back to list</a>
</div>
