@model Laba3.Models.Emp_Prof

@{
    ViewData["Title"] = "Edit Post";
}

<h1>Edit Post</h1>

<div class="page-card" style="max-width: 480px;">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Employee" />
        <div class="form-group">
            <label asp-for="EmployeeID" class="control-label"></label>
            <select asp-for="EmployeeID" class="form-control" asp-items="ViewBag.EmployeeID"></select>
            <span asp-validation-for="EmployeeID" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label asp-for="ProfessionID" class="control-label"></label>
            <select asp-for="ProfessionID" class="form-control" asp-items="ViewBag.ProfessionID"></select>
            <span asp-validation-for="ProfessionID" class="text-danger"></span>
        </div>
        <input type="submit" value="Save" />
    </form>
</div>

<a class="back-link" asp-action="Index">&#8592; Back to list</a>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
