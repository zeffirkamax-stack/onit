@model Laba3.Models.Emp_Prof

@{
    ViewData["Title"] = "New Post";
}

<h1>New Post</h1>

<div class="page-card" style="max-width: 480px;">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-group">
            <label class="control-label">Employee</label>
            <select asp-for="EmployeeID" class="form-control" asp-items="ViewBag.EmployeeID"></select>
        </div>
        <div class="form-group">
            <label class="control-label">Profession</label>
            <select asp-for="ProfessionID" class="form-control" asp-items="ViewBag.ProfessionID"></select>
        </div>
        <input type="submit" value="Create" />
    </form>
</div>

<a class="back-link" asp-action="Index">&#8592; Back to list</a>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
