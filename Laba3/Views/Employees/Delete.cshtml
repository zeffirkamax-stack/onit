@model Laba3.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<h1>Delete Employee</h1>

<div class="info-block">
    <div class="info-row">
        <span class="info-label">@Html.DisplayNameFor(model => model.Id)</span>
        <span class="info-value">@Html.DisplayFor(model => model.Id)</span>
    </div>
    <div class="info-row">
        <span class="info-label">@Html.DisplayNameFor(model => model.Name)</span>
        <span class="info-value">@Html.DisplayFor(model => model.Name)</span>
    </div>
</div>

<p class="delete-warning">Are you sure you want to delete this record?</p>

<form asp-action="Delete" style="display: inline;">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn-danger" />
</form>
&nbsp;
<a asp-action="Index">Cancel</a>
